<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorDarkGreen"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            android:id="@+id/toolbar"
            layout="@layout/toolbar_menu" />

        <!-- TOP HEADER -->
        <RelativeLayout
            android:id="@+id/topHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/toolbar"
            android:elevation="@dimen/corner_elevation_8"
            android:padding="@dimen/padding_14">

            <!-- Greeting Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_6"
                android:layout_marginEnd="@dimen/margin_6"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/padding_6">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileImage"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:adjustViewBounds="true"
                    android:background="@color/colorMilkWhite"
                    android:scaleType="centerCrop"
                    android:tint="@null"
                    app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/padding_10"
                    android:paddingEnd="@dimen/padding_10">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_medium"
                        android:textColor="@color/colorMilkWhite"
                        android:textSize="@dimen/text_14" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:textColor="@color/colorMilkWhite"
                        android:textSize="@dimen/text_16" />
                </LinearLayout>
            </LinearLayout>

            <com.cgr.codrinterraerp.utils.NetworkStatusView
                android:id="@+id/networkStatusView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="@dimen/margin_20"
                android:visibility="visible" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/topHeader"
            android:layout_marginTop="@dimen/margin_10"
            android:background="@drawable/bg_card_corner_top"
            android:orientation="vertical">

            <!-- Section Title -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_24"
                android:layout_marginTop="@dimen/margin_14"
                android:fontFamily="@font/exo2_semibold"
                android:text="@string/main_menu"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_16" />

            <GridLayout
                android:id="@+id/gridDashboardMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/margin_16"
                android:layout_marginTop="@dimen/margin_6"
                android:layout_marginEnd="@dimen/margin_16"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:rowOrderPreserved="false"
                android:useDefaultMargins="true" />
        </LinearLayout>
    </RelativeLayout>

    <include
        layout="@layout/layout_progress_bar"
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include layout="@layout/navigation_drawer" />
</androidx.drawerlayout.widget.DrawerLayout>