<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorMildGreen"
    android:fitsSystemWindows="true">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_back"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_6"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- ROW: ICA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Label -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2_semibold"
                android:gravity="end"
                android:text="@string/container"
                android:textSize="@dimen/text_18" />

            <!-- Colon -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="@string/colon"
                android:textSize="@dimen/text_16" />

            <!-- Value -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvContainerNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/exo2_semibold"
                android:textSize="@dimen/text_18" />
        </LinearLayout>

        <!-- ROW: SUPPLIER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8"
            android:orientation="horizontal">

            <!-- Label -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="130dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2_semibold"
                android:gravity="end"
                android:text="@string/shipping_line"
                android:textSize="@dimen/text_18" />

            <!-- Colon -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="@string/colon"
                android:textSize="@dimen/text_16" />

            <!-- Value -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvShippingLine"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/exo2_semibold"
                android:textSize="@dimen/text_18" />
        </LinearLayout>

        <!-- ROW: PIECES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8"
            android:orientation="horizontal">

            <!-- Label -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2_semibold"
                android:gravity="end"
                android:text="@string/pieces"
                android:textSize="@dimen/text_18" />

            <!-- Colon -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="@string/colon"
                android:textSize="@dimen/text_16" />

            <!-- Value -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPieces"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/exo2_semibold"
                android:textSize="@dimen/text_18" />
        </LinearLayout>

        <!-- ROW: GROSS -->
        <LinearLayout
            android:id="@+id/llGrossVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8"
            android:orientation="horizontal">

            <!-- Label -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2_semibold"
                android:gravity="end"
                android:text="@string/gross_volume"
                android:textSize="@dimen/text_18" />

            <!-- Colon -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="@string/colon"
                android:textSize="@dimen/text_16" />

            <!-- Value -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvGrossVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/exo2_semibold"
                android:textSize="@dimen/text_18" />
        </LinearLayout>

        <!-- ROW: NET -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8"
            android:orientation="horizontal">

            <!-- Label -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2_semibold"
                android:gravity="end"
                android:text="@string/net_volume"
                android:textSize="@dimen/text_18" />

            <!-- Colon -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="@string/colon"
                android:textSize="@dimen/text_16" />

            <!-- Value -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvNetVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/exo2_semibold"
                android:textSize="@dimen/text_18" />
        </LinearLayout>

        <!-- ROW: AVG GIRTH / CFT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_8"
            android:orientation="horizontal">

            <!-- Label -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAvgGirthTitle"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2_semibold"
                android:gravity="end"
                android:text="@string/avg_girth"
                android:textSize="@dimen/text_18" />

            <!-- Colon -->
            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="@string/colon"
                android:textSize="@dimen/text_16" />

            <!-- Value -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAvgGirth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/exo2_semibold"
                android:textSize="@dimen/text_18" />
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvNoDispatchData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_24"
        android:fontFamily="@font/exo2_semibold"
        android:gravity="center"
        android:padding="@dimen/padding_14"
        android:text="@string/no_data_available"
        android:textAllCaps="true"
        android:textColor="@color/colorCharcoal"
        android:textSize="@dimen/text_20"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDispatch"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/colorWhite"
        app:cardCornerRadius="@dimen/corner_radius_10"
        app:cardElevation="@dimen/corner_elevation_8"
        app:cardPreventCornerOverlap="true"
        app:cardUseCompatPadding="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <HorizontalScrollView
            android:id="@+id/hsvDispatchData"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ================= HEADER ================= -->

                <LinearLayout
                    android:id="@+id/llDataRoundLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/colorGrey"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_10">

                    <!-- EMPTY (for buttons) -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/circ"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/length"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/pieces"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/ica"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/gross_volume"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/net_volume"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llDataSquareLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/colorGrey"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_10">

                    <!-- EMPTY (for buttons) -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/thickness"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/width"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/length"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/pieces"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/ica"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/volume_pie"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/exo2_semibold"
                        android:gravity="center_horizontal"
                        android:text="@string/net_volume"
                        android:textColor="@color/colorCharcoal"
                        android:textSize="@dimen/text_16" />
                </LinearLayout>

                <!-- ================= RECYCLER VIEW ================= -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDispatchData"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/row_item_container_data" />

            </LinearLayout>
        </HorizontalScrollView>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>