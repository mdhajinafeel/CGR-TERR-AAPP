<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/cgr_bg">

    <!-- Center Image -->
    <ImageView
        android:id="@+id/centerImage"
        android:layout_width="@dimen/width_300"
        android:layout_height="@dimen/height_100"
        android:contentDescription="@string/app_name"
        android:src="@drawable/cgr_logo"

        app:layout_constraintBottom_toTopOf="@id/appName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        app:layout_constraintVertical_chainStyle="packed" />

    <View
        android:layout_width="match_parent"
        app:layout_constraintTop_toBottomOf="@id/centerImage"
        app:layout_constraintBottom_toTopOf="@id/appName"
        android:layout_marginStart="@dimen/margin_36"
        android:layout_marginEnd="@dimen/margin_36"
        android:background="@color/colorWhite"
        android:layout_height="@dimen/view_height"/>

    <!-- App Name Text -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/exo2_semibold"
        android:text="@string/app_name"
        android:textColor="@color/colorWhite"
        android:textSize="@dimen/text_20"
        android:textStyle="bold"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/centerImage" />

</androidx.constraintlayout.widget.ConstraintLayout>