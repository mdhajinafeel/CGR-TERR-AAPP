<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:cardElevation="@dimen/corner_elevation_8"
    android:layout_gravity="center"
    app:cardCornerRadius="@dimen/corner_radius_16"
    app:cardPreventCornerOverlap="true"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/dialogHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rectangle_solid_green">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvDialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/exo2_bold"
                android:textColor="@color/colorMilkWhite"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="@dimen/margin_16"
                android:textSize="@dimen/text_16"/>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/imgClose"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_close"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="@dimen/margin_10"/>
        </FrameLayout>

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:drawableStart="@drawable/ic_search"
            android:layout_height="wrap_content"
            android:drawablePadding="@dimen/margin_6"
            android:layout_margin="@dimen/margin_10"
            android:padding="@dimen/margin_10"
            android:background="@drawable/solid_rectangle_rounded"
            android:fontFamily="@font/exo2_bold"
            android:textSize="@dimen/text_18" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvNoDataFound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:text="@string/no_data_available"
            android:gravity="center_horizontal"
            android:fontFamily="@font/exo2_bold"
            android:textColor="@color/colorBlack"
            android:layout_marginBottom="@dimen/margin_20"
            android:textSize="@dimen/text_20"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            tools:listitem="@layout/row_dialog_list"
            android:visibility="visible"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnOk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_16"
            android:visibility="gone"
            android:fontFamily="@font/exo2_bold"
            android:textAllCaps="true"
            android:textColor="@color/colorCharcoal"
            android:background="@drawable/bg_button"
            android:enabled="false"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>