<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/width_300"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="start"
    android:clickable="true"
    android:background="@color/colorMilkWhite"
    android:focusable="true"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/topHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorDarkGreen"
        android:orientation="vertical">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_6"
            android:layout_marginTop="@dimen/margin_24"
            android:layout_marginEnd="@dimen/margin_6"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/padding_10">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImageMenu"
                android:layout_width="@dimen/width_80"
                android:layout_height="@dimen/width_80"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:tint="@null"
                android:background="@color/colorMilkWhite"
                app:shapeAppearanceOverlay="@style/RoundedImageStyle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="@dimen/padding_10"
                android:paddingEnd="@dimen/padding_10">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvNameMenu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_10"
                    android:fontFamily="@font/exo2_medium"
                    android:textColor="@color/colorMilkWhite"
                    android:textSize="@dimen/text_16" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/margin_4"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivOriginIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/app_name" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvOriginName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_6"
                        android:fontFamily="@font/exo2_regular"
                        android:textColor="@color/colorMilkWhite"
                        android:textSize="@dimen/text_12" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/margin_10"
            android:layout_marginEnd="@dimen/margin_10"
            android:src="@drawable/ic_close" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/relLogout"
        android:layout_below="@+id/topHeader"
        android:background="@color/colorWhite"
        android:orientation="vertical">

        <ListView
            android:id="@+id/lstMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:choiceMode="singleChoice"
            android:divider="@null"
            tools:listitem="@layout/row_menu_item"
            android:scrollbars="none" />
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/relLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/colorDarkGreen">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginStart="@dimen/margin_10"
            android:drawableStart="@drawable/ic_logout"
            android:drawablePadding="@dimen/padding_10"
            android:fontFamily="@font/exo2_medium"
            android:paddingStart="@dimen/padding_10"
            android:paddingEnd="@dimen/padding_10"
            android:paddingTop="@dimen/padding_20"
            android:paddingBottom="@dimen/padding_20"
            android:text="@string/logout"
            android:textColor="@color/colorWhite"
            android:textSize="@dimen/text_18" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tvLogout"
            android:layout_marginTop="@dimen/margin_10"
            android:fontFamily="@font/exo2_semibold"
            android:layout_marginStart="@dimen/margin_16"
            android:paddingStart="@dimen/padding_10"
            android:paddingEnd="@dimen/padding_10"
            android:paddingBottom="@dimen/margin_10"
            android:textColor="@color/colorWhite"
            android:textSize="@dimen/text_14" />
    </RelativeLayout>
</RelativeLayout>